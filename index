<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zara & Zipp: My Robot Friend Knows Everything!</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&family=Fredoka+One&display=swap');

  :root {
    --sky: #E8F4FF;
    --deep-blue: #1A2E6B;
    --robot-teal: #00B4C6;
    --sunny: #FFD23F;
    --coral: #FF6B6B;
    --mint: #A8EDCA;
    --purple: #9B5DE5;
    --white: #FFFFFF;
    --soft-gray: #F4F6FF;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--soft-gray);
    color: var(--deep-blue);
    overflow-x: hidden;
  }

  /* ── COVER PAGE ── */
  .cover {
    min-height: 100vh;
    background: linear-gradient(160deg, #1A2E6B 0%, #0D1B4B 40%, #00314A 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    position: relative;
    overflow: hidden;
  }

  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 30%, rgba(0,180,198,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(155,93,229,0.2) 0%, transparent 50%);
  }

  .stars {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .star {
    position: absolute;
    background: white;
    border-radius: 50%;
    animation: twinkle 3s infinite alternate;
  }

  @keyframes twinkle {
    from { opacity: 0.2; transform: scale(1); }
    to   { opacity: 1;   transform: scale(1.4); }
  }

  .cover-badge {
    background: var(--sunny);
    color: var(--deep-blue);
    font-family: 'Fredoka One', cursive;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 18px;
    border-radius: 50px;
    margin-bottom: 28px;
    position: relative;
    z-index: 2;
  }

  .cover-robot {
    font-size: 100px;
    animation: float 4s ease-in-out infinite;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 0 30px rgba(0,180,198,0.6));
    margin-bottom: 10px;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(-3deg); }
    50%       { transform: translateY(-18px) rotate(3deg); }
  }

  .cover h1 {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(38px, 7vw, 72px);
    color: var(--white);
    text-align: center;
    line-height: 1.1;
    position: relative;
    z-index: 2;
    text-shadow: 0 4px 20px rgba(0,0,0,0.4);
  }

  .cover h1 span.teal { color: var(--robot-teal); }
  .cover h1 span.yellow { color: var(--sunny); }

  .cover-sub {
    font-size: clamp(16px, 3vw, 22px);
    color: rgba(255,255,255,0.8);
    text-align: center;
    margin-top: 14px;
    position: relative;
    z-index: 2;
    font-weight: 700;
  }

  .cover-author {
    margin-top: 30px;
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    position: relative;
    z-index: 2;
    letter-spacing: 1px;
  }

  .cover-cta {
    margin-top: 36px;
    background: var(--coral);
    color: white;
    font-family: 'Fredoka One', cursive;
    font-size: 20px;
    padding: 16px 40px;
    border-radius: 60px;
    display: inline-block;
    position: relative;
    z-index: 2;
    box-shadow: 0 8px 30px rgba(255,107,107,0.5);
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    animation: pulse-btn 2.5s ease-in-out infinite;
  }

  @keyframes pulse-btn {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.05); }
  }

  .cover-cta:hover { transform: scale(1.08); box-shadow: 0 12px 40px rgba(255,107,107,0.7); }

  /* ── MARKETING STRIP ── */
  .marketing-strip {
    background: var(--sunny);
    padding: 18px;
    text-align: center;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
  }

  .strip-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 900;
    font-size: 14px;
    color: var(--deep-blue);
  }

  .strip-item span { font-size: 20px; }

  /* ── PAGES ── */
  .page {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px 60px;
  }

  /* ── PAGE SPREAD ── */
  .spread {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin: 40px 0;
    align-items: center;
  }

  @media (max-width: 600px) {
    .spread { grid-template-columns: 1fr; }
  }

  .spread-text h2 {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(26px, 5vw, 40px);
    color: var(--deep-blue);
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .spread-text p {
    font-size: clamp(16px, 2.5vw, 20px);
    line-height: 1.7;
    color: #334;
  }

  .scene-box {
    background: var(--sky);
    border-radius: 32px;
    padding: 30px;
    text-align: center;
    font-size: 80px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0,0,80,0.08);
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 8px;
  }

  .scene-label {
    font-family: 'Fredoka One', cursive;
    font-size: 15px;
    color: var(--robot-teal);
    letter-spacing: 1px;
  }

  /* ── COLOR THEMES PER CHAPTER ── */
  .ch-1 .scene-box { background: #E0F7FA; }
  .ch-2 .scene-box { background: #EDE7F6; }
  .ch-3 .scene-box { background: #FFF8E1; }
  .ch-4 .scene-box { background: #E8F5E9; }
  .ch-5 .scene-box { background: #FCE4EC; }
  .ch-6 .scene-box { background: #E3F2FD; }

  /* ── CHAPTER HEADER ── */
  .chapter-header {
    padding: 50px 0 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ch-number {
    font-family: 'Fredoka One', cursive;
    font-size: 64px;
    line-height: 1;
    opacity: 0.12;
    color: var(--deep-blue);
    position: absolute;
    left: -10px;
    top: 40px;
  }

  .ch-pill {
    font-family: 'Fredoka One', cursive;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 50px;
    color: white;
  }

  .ch-1-pill { background: var(--robot-teal); }
  .ch-2-pill { background: var(--purple); }
  .ch-3-pill { background: #F79F1F; }
  .ch-4-pill { background: #1DD1A1; }
  .ch-5-pill { background: var(--coral); }
  .ch-6-pill { background: var(--deep-blue); }

  .chapter-header h2 {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(22px, 4vw, 34px);
    color: var(--deep-blue);
  }

  /* ── FUN FACT BOXES ── */
  .fact-box {
    border-radius: 24px;
    padding: 24px 28px;
    margin: 24px 0;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .fact-box.teal  { background: #E0F7FA; border-left: 6px solid var(--robot-teal); }
  .fact-box.purple{ background: #EDE7F6; border-left: 6px solid var(--purple); }
  .fact-box.yellow{ background: #FFF8E1; border-left: 6px solid var(--sunny); }
  .fact-box.green { background: #E8F5E9; border-left: 6px solid #1DD1A1; }
  .fact-box.pink  { background: #FCE4EC; border-left: 6px solid var(--coral); }

  .fact-icon { font-size: 32px; flex-shrink: 0; }

  .fact-box p {
    font-size: 16px;
    line-height: 1.65;
    color: #334;
  }

  .fact-box strong { color: var(--deep-blue); font-weight: 900; }

  /* ── DIALOGUE ── */
  .dialogue {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin: 18px 0;
  }

  .dialogue.right { flex-direction: row-reverse; }

  .bubble {
    background: white;
    border-radius: 20px;
    padding: 14px 20px;
    font-size: 16px;
    line-height: 1.6;
    box-shadow: 0 4px 16px rgba(0,0,80,0.08);
    max-width: 80%;
    color: #334;
  }

  .bubble.robot { background: #E0F7FA; border-radius: 20px 20px 20px 4px; }
  .bubble.zara  { background: #FCE4EC; border-radius: 20px 20px 4px 20px; }

  .chat-avatar { font-size: 36px; flex-shrink: 0; }

  /* ── QUIZ ── */
  .quiz-box {
    background: linear-gradient(135deg, var(--deep-blue), #0a1a50);
    border-radius: 28px;
    padding: 32px;
    margin: 32px 0;
    color: white;
  }

  .quiz-box h3 {
    font-family: 'Fredoka One', cursive;
    font-size: 24px;
    color: var(--sunny);
    margin-bottom: 20px;
  }

  .quiz-q {
    font-size: 17px;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .quiz-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 14px;
  }

  @media (max-width: 480px) { .quiz-options { grid-template-columns: 1fr; } }

  .quiz-opt {
    background: rgba(255,255,255,0.1);
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 14px;
    padding: 12px 16px;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s;
    color: white;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    text-align: left;
  }

  .quiz-opt:hover { background: rgba(255,255,255,0.2); border-color: var(--sunny); }
  .quiz-opt.correct { background: rgba(29,209,161,0.3); border-color: #1DD1A1; }
  .quiz-opt.wrong   { background: rgba(255,107,107,0.3); border-color: var(--coral); }

  .quiz-result {
    margin-top: 14px;
    font-size: 16px;
    min-height: 28px;
    font-weight: 700;
    color: var(--sunny);
  }

  /* ── ACTIVITY PAGE ── */
  .activity-box {
    background: white;
    border-radius: 28px;
    padding: 32px;
    margin: 32px 0;
    box-shadow: 0 8px 40px rgba(0,0,80,0.06);
  }

  .activity-box h3 {
    font-family: 'Fredoka One', cursive;
    font-size: 24px;
    color: var(--purple);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .steps { display: flex; flex-direction: column; gap: 16px; }

  .step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--robot-teal);
    color: white;
    font-family: 'Fredoka One', cursive;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-text { font-size: 16px; line-height: 1.6; color: #334; padding-top: 4px; }

  /* ── DIVIDER ── */
  .divider {
    text-align: center;
    font-size: 28px;
    letter-spacing: 12px;
    opacity: 0.3;
    margin: 40px 0;
  }

  /* ── BUY BOX ── */
  .buy-box {
    background: linear-gradient(135deg, #FF6B6B, #FF4757);
    border-radius: 32px;
    padding: 48px 36px;
    text-align: center;
    margin: 60px 0 20px;
    color: white;
    box-shadow: 0 20px 60px rgba(255,71,87,0.3);
  }

  .buy-box h2 {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(28px, 5vw, 46px);
    margin-bottom: 14px;
  }

  .buy-box p {
    font-size: 18px;
    opacity: 0.9;
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .price-tag {
    display: inline-block;
    font-family: 'Fredoka One', cursive;
    font-size: 52px;
    margin-bottom: 24px;
  }

  .price-tag .orig {
    font-size: 22px;
    text-decoration: line-through;
    opacity: 0.6;
    display: block;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
  }

  .buy-btn {
    background: white;
    color: var(--coral);
    font-family: 'Fredoka One', cursive;
    font-size: 22px;
    padding: 18px 56px;
    border-radius: 60px;
    display: inline-block;
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
    cursor: pointer;
    transition: transform 0.2s;
    text-decoration: none;
  }

  .buy-btn:hover { transform: scale(1.06); }

  .guarantee {
    margin-top: 20px;
    font-size: 14px;
    opacity: 0.75;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  /* ── TESTIMONIALS ── */
  .testimonials {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 20px;
    margin: 40px 0;
  }

  .testi {
    background: white;
    border-radius: 22px;
    padding: 24px;
    box-shadow: 0 6px 24px rgba(0,0,80,0.07);
  }

  .testi-stars { color: var(--sunny); font-size: 18px; margin-bottom: 10px; }

  .testi p {
    font-size: 15px;
    line-height: 1.65;
    color: #445;
    margin-bottom: 14px;
  }

  .testi-name {
    font-weight: 900;
    font-size: 14px;
    color: var(--deep-blue);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* ── SECTION HEADLINE ── */
  .section-headline {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(28px, 5vw, 44px);
    color: var(--deep-blue);
    text-align: center;
    margin: 60px 0 8px;
  }

  .section-sub {
    text-align: center;
    color: #778;
    font-size: 17px;
    margin-bottom: 36px;
  }

  /* ── WHAT YOU'LL LEARN ── */
  .learn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 18px;
    margin: 28px 0;
  }

  .learn-card {
    background: white;
    border-radius: 22px;
    padding: 24px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,80,0.06);
    transition: transform 0.2s;
  }

  .learn-card:hover { transform: translateY(-4px); }

  .learn-icon { font-size: 42px; margin-bottom: 12px; }

  .learn-card h4 {
    font-family: 'Fredoka One', cursive;
    font-size: 18px;
    color: var(--deep-blue);
    margin-bottom: 6px;
  }

  .learn-card p { font-size: 14px; color: #556; line-height: 1.5; }

  /* ── BACK COVER / FOOTER ── */
  .back-cover {
    background: var(--deep-blue);
    padding: 60px 20px;
    text-align: center;
    color: white;
  }

  .back-cover h3 {
    font-family: 'Fredoka One', cursive;
    font-size: 32px;
    margin-bottom: 14px;
    color: var(--sunny);
  }

  .back-cover p { font-size: 17px; opacity: 0.75; max-width: 500px; margin: 0 auto; }

  hr.chapter-rule {
    border: none;
    border-top: 2px dashed rgba(0,0,80,0.1);
    margin: 40px 0;
  }

  .page-num {
    text-align: right;
    font-size: 13px;
    color: #aab;
    margin-top: -30px;
    margin-bottom: 20px;
  }
</style>
</head>
